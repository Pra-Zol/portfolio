# ============================================
# ENVIRONMENT VARIABLES — copy this to .env
# ============================================

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Connection
# Option 1: Local PostgreSQL
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/portfolio_db

# Option 2: Neon (FREE cloud PostgreSQL - recommended!)
# Sign up at https://neon.tech — no install needed
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/portfolio_db?sslmode=require

# Option 3: Supabase (FREE cloud PostgreSQL)
# DATABASE_URL=postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Notifications (optional)
SMTP_USER=off.pklm10@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Admin Key (to view messages via API)
ADMIN_KEY=prajwal_admin_secret_2025
